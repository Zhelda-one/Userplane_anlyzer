	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-diagnostics-conf {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:diagnostics-conf:1.0";
  prefix ran-ru-diagnostics-conf;

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension module capabilities for diagnostics configuration.

     Copyright 2025 Nokia";

  revision 2025-07-22 {
    description
      "Module v0.2:
       1) Added value range limitation to input-voltage-high/low/unstable-threshold leafs and removed default values";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v19.0T0.1";
  }
  revision 2024-08-01 {
    description
      "Module v0.1:
       1) Initial draft containing definitions for diagnostics parity to RP1/SOAP";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v1.1";
  }

  feature INPUT-VOLTAGE-MONITORING;

  grouping input-voltage-monitoring-config {
    container input-voltage-monitoring-conf {
      leaf input-voltage-high-threshold {
        type uint32 {
          range "57000 .. 60000 | 240000 .. 300000";
        }
      }
      leaf input-voltage-low-threshold {
        type uint32 {
          range "36000 .. 40500 | 76000 .. 100000";
        }
      }
      leaf input-voltage-unstable-threshold {
        type uint32 {
          range "1 .. 10";
        }
      }
    }
  }

  container diagnostics-configuration {
    description
      "top level container for diagnostics parameters and configuration";
    uses input-voltage-monitoring-config {
      if-feature "INPUT-VOLTAGE-MONITORING";
    }
  }
}
</data>
