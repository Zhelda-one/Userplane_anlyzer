<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="20">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-uplane-aug {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:uplane-aug:1.0";
  prefix ran-ru-uplane-aug;

  import o-ran-uplane-conf {
    prefix up;
  }
  import nokia-ran-ru-uplane-conf {
    prefix ran-ru-uplane-conf;
  }

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary augmentations to the O-RAN Radio Unit U-Plane configuration.

     Copyright 2026 Nokia";

  revision 2026-01-27 {
    description
      "Module v0.6:
       1) [CB015283/CB015284] Introduced power pooling for downlink array carriers";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v31.0T2.3";
  }
  revision 2026-01-23 {
    description
      "Module v0.5:
       1) [CB014308-B] Added leaf for configurable TDD pattern for 7-2e array carriers.";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v32.0T0.2";
  }
  revision 2025-12-08 {
    description
      "Module v0.4:
       1) [CB014309-J] Added control for exclusion of TX array carriers from No Tx Data Detection procedure.

       Module v0.3:
       1) [CB014309-D] Added control of U-Plane fragmentation on low level RX/TX endpoint level.

       Module v0.2:
       1) [CB014309-A/G] Added reporting of faulty array elements for RX/TX array carriers.";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v26.0T1.2";
  }
  revision 2025-10-08 {
    description
      "Module v0.1:
       1) [CB008577-C] Initial definition of module with augmentation of low-level-rx-endpoints to enable split-panel
       beam selection via sectionId in C-Plane.";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v23.0T0.1";
  }

  feature SPLIT-PANEL-BEAM-SELECTION-MODE;

  feature SPLIT-PANEL-BEAM-SELECTION-SECTIONID;

  feature ARRAY-ELEMENT-PROBLEMS;

  feature UPLANE-FRAGMENTATION-CONTROL;

  feature NO-TX-DATA-DETECTION-EXCLUDED-CARRIER;

  feature CONFIGURABLE-TDD-PATTERN-72E-SUPPORTED;

  grouping array-element-problems {
    list array-element-problems {
      key "array array-element-id";
      config false;
      leaf array {
        type string;
      }
      leaf array-element-id {
        type uint16;
      }
      leaf code {
        type uint32;
      }
    }
  }

  grouping configurable-tdd-pattern-72e {
    leaf configurable-tdd-pattern-72e {
      type leafref {
        path "/up:user-plane-configuration/up:configurable-tdd-patterns/up:tdd-pattern-id";
      }
    }
  }

  augment "/up:user-plane-configuration/up:endpoint-types" {
    if-feature "SPLIT-PANEL-BEAM-SELECTION-MODE";
    leaf split-panel-beam-selection-sectionid-supported {
      if-feature "SPLIT-PANEL-BEAM-SELECTION-SECTIONID";
      type boolean;
      default "false";
    }
  }
  augment "/up:user-plane-configuration/up:low-level-rx-endpoints" {
    if-feature "SPLIT-PANEL-BEAM-SELECTION-MODE";
    leaf split-panel-beam-selection-mode {
      type enumeration {
        enum "NONE";
        enum "SECTION-ID" {
          if-feature "SPLIT-PANEL-BEAM-SELECTION-SECTIONID";
        }
      }
      default "NONE";
    }
  }
  augment "/up:user-plane-configuration/up:rx-array-carriers" {
    if-feature "ARRAY-ELEMENT-PROBLEMS";
    uses array-element-problems;
  }
  augment "/up:user-plane-configuration/up:tx-array-carriers" {
    if-feature "ARRAY-ELEMENT-PROBLEMS";
    uses array-element-problems;
  }
  augment "/up:user-plane-configuration/up:low-level-rx-endpoints" {
    if-feature "UPLANE-FRAGMENTATION-CONTROL";
    leaf uplane-fragmentation-enabled {
      type boolean;
      default "true";
    }
  }
  augment "/up:user-plane-configuration/up:low-level-tx-endpoints" {
    if-feature "UPLANE-FRAGMENTATION-CONTROL";
    leaf uplane-fragmentation-enabled {
      type boolean;
      default "true";
    }
  }
  augment "/up:user-plane-configuration" {
    if-feature "NO-TX-DATA-DETECTION-EXCLUDED-CARRIER";
    list no-tx-data-detection-excluded-carriers {
      key "tx-array-carrier";
      leaf tx-array-carrier {
        type leafref {
          path "/up:user-plane-configuration/up:tx-array-carriers/up:name";
          require-instance false;
        }
      }
    }
  }
  augment "/up:user-plane-configuration/up:rx-array-carriers" {
    if-feature "CONFIGURABLE-TDD-PATTERN-72E-SUPPORTED";
    uses configurable-tdd-pattern-72e {
      when "(not(./up:configurable-tdd-pattern))\nand\n(not(/up:user-plane-configuration/up:low-level-rx-endpoints[up:name = /up:user-plane-configuration/up:low-level-rx-links[up:rx-array-carrier = current()/up:name]/up:rx-array-carrier]/up:configurable-tdd-pattern-supported = 'false'))";
    }
  }
  augment "/up:user-plane-configuration/up:tx-array-carriers" {
    if-feature "CONFIGURABLE-TDD-PATTERN-72E-SUPPORTED";
    uses configurable-tdd-pattern-72e {
      when "(not(./up:configurable-tdd-pattern))\nand\n(not(/up:user-plane-configuration/up:low-level-tx-endpoints[up:name = /up:user-plane-configuration/up:low-level-tx-links[up:tx-array-carrier = current()/up:name]/up:tx-array-carrier]))";
    }
  }
  augment "/up:user-plane-configuration/up:tx-array-carriers" {
    if-feature "ran-ru-uplane-conf:PA-POWER-POOLING";
    leaf pa-power-pool {
      type leafref {
        path "/ran-ru-uplane-conf:user-plane-configuration/ran-ru-uplane-conf:pa-power-pools/ran-ru-uplane-conf:name";
      }
    }
  }

  notification array-element-problem-change {
    if-feature "ARRAY-ELEMENT-PROBLEMS";
    list array-element-problem-changes {
      key "array-carrier direction array array-element-id";
      leaf array-carrier {
        type string;
        mandatory true;
      }
      leaf direction {
        type enumeration {
          enum "UPLINK";
          enum "DOWNLINK";
        }
        mandatory true;
      }
      leaf array {
        type string;
        mandatory true;
      }
      leaf array-element-id {
        type uint16;
        mandatory true;
      }
      leaf code {
        type uint32;
      }
    }
  }
}
</data>
