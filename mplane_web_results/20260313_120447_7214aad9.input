<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="8">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-hardware {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:hardware:1.0";
  prefix ran-ru-hardware;

  import ietf-hardware {
    prefix hw;
  }
  import o-ran-hardware {
    prefix o-ran-hw;
  }
  import o-ran-uplane-conf {
    prefix up;
  }

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension for managing the O-RAN hardware.

     Copyright 2024 Nokia";

  revision 2025-11-18 {
    description
      "Module v0.2:
       1) [CB013489] Added TX-ARRAY-RATING feature.";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v26.0T2.1";
  }
  revision 2024-11-06 {
    description
      "Module v0.1:
       1) [CB012186] Initial module definition";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v6.0T0.2";
  }

  feature TX-ARRAY-RATING;

  typedef temperature-rating {
    type enumeration {
      enum "NORMAL";
      enum "INCREASED";
      enum "HIGH";
    }
  }

  augment "/hw:hardware/hw:component" {
    when "(derived-from-or-self(hw:class, 'o-ran-hw:O-RAN-RADIO'))";
    container temperature-state {
      config false;
      container rating {
        leaf value {
          type temperature-rating;
        }
        leaf counter {
          type uint32;
        }
      }
      list tx-array-rating {
        if-feature "TX-ARRAY-RATING";
        key "tx-array";
        leaf tx-array {
          type leafref {
            path "/up:user-plane-configuration/up:tx-arrays/up:name";
            require-instance false;
          }
        }
        leaf value {
          type temperature-rating;
        }
        leaf counter {
          type uint32;
        }
      }
    }
  }

  notification temperature-rating-change {
    leaf name {
      type leafref {
        path "/hw:hardware/hw:component/hw:name";
      }
    }
    container rating {
      leaf value {
        type leafref {
          path "/hw:hardware/hw:component/ran-ru-hardware:temperature-state/ran-ru-hardware:rating/ran-ru-hardware:value";
        }
      }
      leaf counter {
        type leafref {
          path "/hw:hardware/hw:component/ran-ru-hardware:temperature-state/ran-ru-hardware:rating/ran-ru-hardware:counter";
        }
      }
    }
    list tx-array-rating {
      if-feature "TX-ARRAY-RATING";
      key "tx-array";
      leaf tx-array {
        type leafref {
          path "/hw:hardware/hw:component/ran-ru-hardware:temperature-state/ran-ru-hardware:tx-array-rating/ran-ru-hardware:tx-array";
        }
      }
      leaf value {
        type leafref {
          path "/hw:hardware/hw:component/ran-ru-hardware:temperature-state/ran-ru-hardware:tx-array-rating[tx-array = current()/../tx-array]/ran-ru-hardware:value";
        }
      }
      leaf counter {
        type leafref {
          path "/hw:hardware/hw:component/ran-ru-hardware:temperature-state/ran-ru-hardware:tx-array-rating[tx-array = current()/../tx-array]/ran-ru-hardware:counter";
        }
      }
    }
  }
}
</data>
</rpc-reply>
