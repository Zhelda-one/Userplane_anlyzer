  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension module capabilities for diagnostics configuration.

     Copyright 2025 Nokia";

  revision 2025-07-22 {
    description
      "Module v0.2:
       1) Added value range limitation to input-voltage-high/low/unstable-threshold leafs and removed default values";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v19.0T0.1";
  }
  revision 2024-08-01 {
    description
