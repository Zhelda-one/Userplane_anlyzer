<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="12">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-performance-management {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:performance-management:1.0";
  prefix ran-ru-performance-management;

  import ietf-yang-types {
    prefix yang-types;
    revision-date 2013-07-15;
  }
  import iana-if-type {
    prefix ianaift;
  }
  import ietf-interfaces {
    prefix if;
  }
  import o-ran-interfaces {
    prefix o-ran-int;
  }
  import o-ran-performance-management {
    prefix o-ran-pm;
  }
  import o-ran-uplane-conf {
    prefix up;
  }
  import o-ran-fan {
    prefix o-ran-fan;
  }

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension module capabilities for performance management.

     Copyright 2025 Nokia";

  revision 2025-09-22 {
    description
      "Module v0.5:
       1) [CB013212] Corrected 'must' statement for object-unit-id leaf in ethernet-measurement-result-grouping";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v17.0T0.4";
  }
  revision 2025-07-07 {
    description
      "Module v0.5:
       1) [CB013668] Added support for fan speed measurements";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v17.0T0.4";
  }
  revision 2024-12-06 {
    description
      "Module v0.4:
       1) [CB013427]: Added support for DWDM errors";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v6.0T1.2";
  }
  revision 2024-11-06 {
    description
      "Module v0.3:
       1) [CB012186]: Added support for RX antenna measurements";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v6.0T0.2";
  }
  revision 2024-10-09 {
    description
      "Module v0.2:
       1) [CB013298-B]: Added support for the following Ethernet measurement objects:
        * RECEIVED_ERRORED_FRAMES
        * RECEIVED_MULTICAST_FRAMES
        * RECEIVED_UNKNOWN_VLAN_FRAMES
        * RECEIVED_UNKNOWN_TYPE_FRAMES
        * RECEIVED_OCTETS
        * TRANSMITTED_FRAMES
        * TRANSMITTED_MULTICAST_FRAMES
        * TRANSMITTED_OCTETS.";
  }
  revision 2024-09-12 {
    description
      "Module v0.1:
       1) Initial draft containing definitions for Ethernet interface and transceiver performance management parity to RP1/SOAP";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v3.1";
  }

  typedef percent {
    type uint8 {
      range "0 .. 100";
    }
  }

  typedef ethernet-report-info {
    type enumeration {
      enum "COUNT";
    }
  }

  typedef transceiver2-report-info {
    type enumeration {
      enum "MAXIMUM";
      enum "MINIMUM";
      enum "FIRST";
      enum "LATEST";
      enum "FREQUENCY_TABLE";
    }
  }

  typedef transceiver2-function {
    type enumeration {
      enum "RAW";
      enum "LOG_10";
    }
  }

  typedef rx-antenna-report-info {
    type enumeration {
      enum "MAXIMUM";
      enum "MINIMUM";
      enum "SUM";
      enum "SAMPLE_COUNT";
    }
  }

  typedef rx-antenna-object-unit {
    type enumeration {
      enum "ARRAY_ELEMENT";
    }
  }

  typedef fan-report-info {
    type enumeration {
      enum "LATEST_AND_TIME";
    }
  }

  grouping ethernet-measurement-result-grouping {
    list ethernet-measurement-result {
      key "object-unit-id";
      config false;
      leaf object-unit-id {
        type uint8;
      }
      leaf count {
        type uint64;
      }
    }
  }

  grouping transceiver2-measurement-result-grouping {
    list transceiver2-measurement-result {
      key "object-unit-id";
      config false;
      leaf object-unit-id {
        type leafref {
          path "/if:interfaces/if:interface/o-ran-int:port-reference/o-ran-int:port-number";
          require-instance false;
        }
      }
      container min {
        leaf value {
          type decimal64 {
            fraction-digits 4;
          }
        }
        leaf time {
          type yang-types:date-and-time;
        }
      }
      container max {
        leaf value {
          type decimal64 {
            fraction-digits 4;
          }
        }
        leaf time {
          type yang-types:date-and-time;
        }
      }
      container first {
        leaf value {
          type decimal64 {
            fraction-digits 4;
          }
        }
        leaf time {
          type yang-types:date-and-time;
        }
      }
      container latest {
        leaf value {
          type decimal64 {
            fraction-digits 4;
          }
        }
        leaf time {
          type yang-types:date-and-time;
        }
      }
      list frequency-bin-table {
        key "bin-id";
        leaf bin-id {
          type uint32;
        }
        leaf value {
          type uint32;
        }
      }
    }
  }

  grouping rx-antenna-measurement-result-grouping {
    grouping rx-antenna-measurement-values-grouping {
      leaf min {
        type uint32;
      }
      leaf max {
        type uint32;
      }
      leaf sum {
        type uint32;
      }
      leaf sample-count {
        type uint32;
      }
    }
    choice object-unit-id {
      config false;
      case ARRAY_ELEMENT {
        list rx-antenna-measurement-result-array-element {
          key "rx-array rx-array-element";
          config false;
          leaf rx-array {
            type leafref {
              path "/up:user-plane-configuration/up:rx-arrays/up:name";
              require-instance false;
            }
          }
          leaf rx-array-element {
            type uint16;
          }
          uses rx-antenna-measurement-values-grouping;
        }
      }
    }
  }

  grouping fan-measurement-result-grouping {
    list fan-measurement-result {
      key "object-unit-id";
      config false;
      leaf object-unit-id {
        type leafref {
          path "/o-ran-fan:fan-tray/o-ran-fan:fan-state/o-ran-fan:name";
          require-instance false;
        }
      }
      container latest {
        leaf value {
          type percent;
        }
        leaf time {
          type yang-types:date-and-time;
        }
      }
    }
  }

  augment "/o-ran-pm:performance-measurement-objects" {
    leaf ethernet-measurement-interval {
      type uint16;
      units "seconds";
    }
    list ethernet-measurement-objects {
      key "measurement-object";
      leaf measurement-object {
        type enumeration {
          enum "RECEIVED_FRAMES";
          enum "RECEIVED_CRC_ERRORED_FRAMES";
          enum "RECEIVED_FEC_CORRECTABLE_CODEWORDS";
          enum "RECEIVED_FEC_UNCORRECTABLE_CODEWORDS";
          enum "RECEIVER_PCS_STATUS_CHANGE_COUNT";
          enum "RECEIVED_ERRORED_FRAMES";
          enum "RECEIVED_MULTICAST_FRAMES";
          enum "RECEIVED_UNKNOWN_VLAN_FRAMES";
          enum "RECEIVED_UNKNOWN_TYPE_FRAMES";
          enum "RECEIVED_OCTETS";
          enum "TRANSMITTED_FRAMES";
          enum "TRANSMITTED_MULTICAST_FRAMES";
          enum "TRANSMITTED_OCTETS";
        }
      }
      leaf active {
        type boolean;
        default "false";
      }
      leaf-list report-info {
        type ethernet-report-info;
      }
      leaf object-unit {
        type enumeration {
          enum "PORT_NUMBER";
        }
        mandatory true;
      }
      uses ethernet-measurement-result-grouping;
    }
  }
  augment "/o-ran-pm:performance-measurement-objects/o-ran-pm:measurement-capabilitites" {
    list ethernet-objects {
      key "measurement-object";
      leaf measurement-object {
        type leafref {
          path "/o-ran-pm:performance-measurement-objects/ethernet-measurement-objects/measurement-object";
          require-instance false;
        }
      }
    }
  }
  augment "/o-ran-pm:measurement-result-stats" {
    list ethernet-stats {
      key "measurement-object";
      leaf measurement-object {
        type leafref {
          path "/o-ran-pm:performance-measurement-objects/ethernet-measurement-objects/measurement-object";
          require-instance false;
        }
      }
      list ethernet-measurement-results {
        config false;
        uses o-ran-pm:start-and-end-time;
        uses ethernet-measurement-result-grouping;
      }
    }
  }
  augment "/o-ran-pm:performance-measurement-objects" {
    list transceiver2-measurement-objects {
      key "measurement-object";
      leaf measurement-object {
        type enumeration {
          enum "TEC_CURRENT";
          enum "LASER_TEMPERATURE";
          enum "TUNED_DWDM_CHANNEL_FREQUENCY_ERROR";
          enum "TUNED_DWDM_CHANNEL_WAVELENGTH_ERROR";
        }
      }
      leaf active {
        type boolean;
        default "false";
      }
      leaf-list report-info {
        type transceiver2-report-info;
      }
      leaf object-unit {
        type enumeration {
          enum "PORT_NUMBER";
        }
        mandatory true;
      }
      leaf function {
        type transceiver2-function;
      }
      leaf bin-count {
        type uint16;
      }
      leaf lower-bound {
        type decimal64 {
          fraction-digits 4;
        }
      }
      leaf upper-bound {
        type decimal64 {
          fraction-digits 4;
        }
      }
      uses transceiver2-measurement-result-grouping;
    }
  }
  augment "/o-ran-pm:performance-measurement-objects/o-ran-pm:measurement-capabilitites" {
    list transceiver2-objects {
      key "measurement-object";
      leaf measurement-object {
        type leafref {
          path "/o-ran-pm:performance-measurement-objects/transceiver2-measurement-objects/measurement-object";
          require-instance false;
        }
      }
      leaf-list report-info {
        type transceiver2-report-info;
      }
      leaf-list function {
        type transceiver2-function;
      }
      leaf max-bin-count {
        type uint16;
      }
    }
  }
  augment "/o-ran-pm:measurement-result-stats" {
    list transceiver2-stats {
      key "measurement-object";
      leaf measurement-object {
        type leafref {
          path "/o-ran-pm:performance-measurement-objects/transceiver2-measurement-objects/measurement-object";
          require-instance false;
        }
      }
      list transceiver2-measurement-results {
        config false;
        uses o-ran-pm:start-and-end-time;
        uses transceiver2-measurement-result-grouping;
      }
    }
  }
  augment "/o-ran-pm:performance-measurement-objects" {
    list rx-antenna-measurement-objects {
      key "measurement-object";
      leaf measurement-object {
        type enumeration {
          enum "PIM";
        }
      }
      leaf active {
        type boolean;
        default "false";
      }
      leaf-list report-info {
        type rx-antenna-report-info;
      }
      leaf object-unit {
        type rx-antenna-object-unit;
        mandatory true;
      }
      uses rx-antenna-measurement-result-grouping;
    }
  }
  augment "/o-ran-pm:performance-measurement-objects/o-ran-pm:measurement-capabilitites" {
    list rx-antenna-stats-objects {
      key "measurement-object";
      leaf measurement-object {
        type leafref {
          path "/o-ran-pm:performance-measurement-objects/rx-antenna-measurement-objects/measurement-object";
          require-instance false;
        }
      }
      leaf-list object-unit {
        type rx-antenna-object-unit;
      }
      leaf-list report-info {
        type rx-antenna-report-info;
      }
    }
  }
  augment "/o-ran-pm:measurement-result-stats" {
    list rx-antenna-stats {
      key "measurement-object";
      leaf measurement-object {
        type leafref {
          path "/o-ran-pm:performance-measurement-objects/rx-antenna-measurement-objects/measurement-object";
          require-instance false;
        }
      }
      list rx-antenna-measurement-result {
        config false;
        uses o-ran-pm:start-and-end-time;
        uses rx-antenna-measurement-result-grouping;
      }
    }
  }
  augment "/o-ran-pm:performance-measurement-objects" {
    leaf fan-measurement-interval {
      type uint16;
      units "seconds";
    }
    list fan-measurement-objects {
      key "measurement-object";
      leaf measurement-object {
        type enumeration {
          enum "SPEED";
        }
      }
      leaf active {
        type boolean;
        default "false";
      }
      leaf-list report-info {
        type fan-report-info;
      }
      leaf object-unit {
        type enumeration {
          enum "FAN";
        }
        mandatory true;
      }
      uses fan-measurement-result-grouping;
    }
  }
  augment "/o-ran-pm:performance-measurement-objects/o-ran-pm:measurement-capabilitites" {
    list fan-objects {
      key "measurement-object";
      leaf measurement-object {
        type leafref {
          path "/o-ran-pm:performance-measurement-objects/fan-measurement-objects/measurement-object";
          require-instance false;
        }
      }
      leaf-list report-info {
        type fan-report-info;
