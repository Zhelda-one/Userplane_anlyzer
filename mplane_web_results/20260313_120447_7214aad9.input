<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="13">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-permanent-data {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:permanent-data:1.0";
  prefix ran-ru-permanent;

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension for storage of data in non-volatile memory of O-RU.

     Copyright 2024 Nokia";

  revision 2024-11-19 {
    description
      "Module v0.1:
