  }

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extensions for PIM (passive intermodulation) cancellation configuration.

     Copyright 2024 Nokia";

  revision 2024-11-06 {
    description
      "Module v0.1:
       1) [CB012186] Initial module definition containing configuration of PIM cancellation and thresholds for the related alarms";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v6.0T0.2";
  }

  grouping pim-cancellation-config {
