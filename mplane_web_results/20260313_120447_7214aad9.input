<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="3">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-antl-conf {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:antl-conf:1.0";
  prefix ran-ru-antl-conf;

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extensions for the O-RAN Radio Unit antenna line configuration.

     Copyright 2024 Nokia";

  revision 2024-06-20 {
    description
      "Module v0.1:
       1) [CB010810] Added support for configuring RX array elements with external gain and antenna line status";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v0.4";
  }

  feature RX-EXTERNAL-GAIN;

  feature ANTENNA-LINE-STATUS;

  grouping external-gain-config {
    description
      "Grouping for configuration of RX external gain";
    list external-gain-conf {
      key "rx-array-name array-element-id";
      config true;
      leaf rx-array-name {
        type string;
      }
      leaf array-element-id {
        type uint16;
      }
      leaf external-gain {
        type decimal64 {
          fraction-digits 4;
        }
        default "0";
      }
    }
  }

  grouping antenna-line-status-config {
    description
      "Grouping for configuration of antenna line status";
    list antenna-line-status-conf {
      key "array-name array-type array-element-id";
      config true;
      leaf array-name {
        type string;
      }
      leaf array-type {
        type enumeration {
          enum "TX-ARRAY";
          enum "RX-ARRAY";
        }
      }
      leaf array-element-id {
        type uint16;
      }
      leaf antenna-line-status {
        type enumeration {
          enum "NORMAL";
          enum "DEGRADED";
          enum "FAULTY";
        }
        default "NORMAL";
      }
    }
  }

  container antenna-line-configuration {
    description
      "top level container for antenna line configuration";
    uses external-gain-config {
      if-feature "RX-EXTERNAL-GAIN";
    }
    uses antenna-line-status-config {
      if-feature "ANTENNA-LINE-STATUS";
    }
  }
}
</data>
</rpc-reply>
