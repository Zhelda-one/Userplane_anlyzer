       1) Initial draft containing definitions for diagnostics parity to RP1/SOAP";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v1.1";
  }

  feature INPUT-VOLTAGE-MONITORING;

  grouping input-voltage-monitoring-config {
