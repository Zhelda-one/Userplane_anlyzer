<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="6">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-fcp-triggered-captures {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:fcp-triggered-captures:1.0";
  prefix ran-ru-fcp-triggered-captures;

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension module for FCP triggered captures.

     Copyright 2025 Nokia";

  revision 2025-10-16 {
    description
      "Module v0.2:
       1) [CB014308-C]: Added leaf capture-mode to array-element-set list in capabilities container
                                           and to capture-points list in captures list.";
  }
  revision 2024-10-09 {
    description
      "Module v0.1:
       1) [CB013298-A]: Added support for FCP triggered captures configuration and capabilities.";
  }

  grouping capabilities {
    container capabilities {
      config false;
      leaf max-number-of-captures {
        type uint32 {
          range "1..max";
        }
        mandatory true;
      }
      list array-element-sets {
        min-elements 1;
        list array-element-set {
          min-elements 1;
          leaf array-name {
            type string;
            mandatory true;
          }
          leaf direction {
            type enumeration {
              enum "DL";
              enum "UL";
            }
            mandatory true;
          }
          leaf-list array-elements {
            type uint32;
          }
          leaf capture-mode {
            type enumeration {
              enum "TD";
              enum "FD";
              enum "FD-POSTBF";
            }
            default "TD";
          }
        }
      }
      leaf buffer-cycle-min-value {
        type uint32;
        mandatory true;
      }
    }
  }

  grouping captures {
    list captures {
      key "name";
      leaf name {
        type string;
      }
      leaf active {
        type boolean;
        default "true";
      }
      leaf buffer-cycle {
        type uint32 {
          range "1|2|4|8|16|32|64|128|256|512|1024";
        }
        mandatory true;
      }
      leaf capture-activity-timer {
        type uint32 {
          range "0..43200";
        }
        mandatory true;
      }
      leaf capture-frame-offset {
        type uint32 {
          range "0..1023";
        }
        mandatory true;
      }
      list capture-points {
        key "id";
        min-elements 1;
        leaf id {
          type uint32;
        }
        leaf cell-id {
          type uint32;
          mandatory true;
        }
        leaf direction {
          type enumeration {
            enum "DL";
            enum "UL";
          }
          mandatory true;
        }
        leaf array-carrier {
          type string;
          mandatory true;
        }
        leaf array {
          type string;
          mandatory true;
        }
        leaf-list array-elements {
          type uint32;
        }
        leaf capture-mode {
          type leafref {
            path "/fcp-triggered-captures/capabilities/array-element-sets/array-element-set/capture-mode";
            require-instance false;
          }
        }
      }
      leaf state {
        type enumeration {
          enum "RUNNING";
          enum "SUSPENDED";
          enum "FAILED";
        }
        config false;
        mandatory true;
      }
      leaf additional-state-information {
        when "../state = 'FAILED'";
        type enumeration {
          enum "SW_UPDATE";
          enum "INTERNAL_PROCEDURE_ONGOING";
          enum "CARRIER_DEACTIVATED";
          enum "CAPTURE_TIMEOUT";
          enum "TECHLOG_OTHER_NETCONF_CLIENT";
          enum "TECHLOG_WRONG_STATE";
          enum "OTHER";
        }
        config false;
      }
    }
  }

  container fcp-triggered-captures {
    uses capabilities;
    uses captures;
  }

  notification fcp-triggered-capture-state-change {
    leaf name {
      type leafref {
        path "/fcp-triggered-captures/captures/name";
      }
      mandatory true;
    }
    leaf state {
      type leafref {
        path "/fcp-triggered-captures/captures[name = current()/../name]/state";
      }
      mandatory true;
    }
    leaf additional-state-information {
      type leafref {
        path "/fcp-triggered-captures/captures[name = current()/../name]/additional-state-information";
      }
    }
  }
}
</data>
</rpc-reply>
