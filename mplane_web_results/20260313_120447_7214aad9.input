	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module o-ran-performance-management {
  yang-version 1.1;
  namespace "urn:o-ran:performance-management:1.0";
  prefix o-ran-pm;

  import ietf-yang-types {
    prefix yang-types;
  }
  import ietf-hardware {
    prefix hw;
  }
  import ietf-interfaces {
    prefix if;
  }
  import ietf-inet-types {
    prefix inet;
  }
  import o-ran-interfaces {
    prefix o-ran-int;
  }
  import o-ran-processing-element {
    prefix o-ran-elements;
  }
  import o-ran-file-management {
    prefix o-ran-file-mgmt;
  }
  import iana-hardware {
    prefix ianahw;
  }
  import o-ran-uplane-conf {
    prefix up;
