  namespace "urn:nokia.com:ran:ru:interfaces:1.0";
  prefix ran-ru-if;

  import iana-if-type {
    prefix ianaift;
  }
  import ietf-interfaces {
    prefix if;
  }

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension for managing O-RAN interfaces.

     Copyright 2025 Nokia";

  revision 2025-01-02 {
    description
      "Module v0.1:
       1) [CB013490-D] Initial module definition";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v8.0T1.2";
  }

  augment "/if:interfaces/if:interface" {
    when "if:type = 'ianaift:ethernetCsmacd'";
    leaf receiver-pcs-status {
      type enumeration {
        enum "OPERATIONAL";
        enum "NOT-OPERATIONAL";
      }
      config false;
    }
  }

  notification interface-state-change {
    leaf name {
      type leafref {
        path "/if:interfaces/if:interface/if:name";
      }
      mandatory true;
    }
    leaf receiver-pcs-status {
      type leafref {
        path "/if:interfaces/if:interface[if:name = current()/../name]/ran-ru-if:receiver-pcs-status";
      }
    }
  }
}
