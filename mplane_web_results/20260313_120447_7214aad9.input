[2026-02-23 16:57:23.640034];RECV;2833bytes
<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="15">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-rf-scan-captures {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:rf-scan-captures:1.0";
  prefix ran-ru-rf-scan-captures;

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension module for RF scan captures.

     Copyright 2025 Nokia";

  revision 2025-11-13 {
    description
      "Module v0.2:
       1) [CB014308-C]: Added feature flag DUAL-POL-CAPTURE to indicate support of signal capture for dual polarization
       arrays.";
  }
  revision 2024-11-12 {
    description
      "Module v0.1:
       1) [CB013298-D]: Added support for FCP triggered captures configuration and capabilities.";
  }

  feature DUAL-POL-CAPTURE;

  typedef rf-scan-capture-point {
    type enumeration {
      enum "TX_FEEDBACK";
      enum "RX_COMBINED";
      enum "RX_CARRIER";
    }
  }

  grouping capabilities {
    container capabilities {
      config false;
      leaf-list capture-points {
        type rf-scan-capture-point;
        min-elements 1;
      }
    }
  }

  grouping captures {
    list captures {
      key "name";
      leaf name {
        type string;
      }
      leaf capture-point {
        type rf-scan-capture-point;
        mandatory true;
      }
      leaf max-interval {
        type uint32;
        default "10";
      }
      list arrays {
        key "array direction";
        min-elements 1;
        leaf array {
          type string;
        }
        leaf direction {
          type enumeration {
            enum "DL";
            enum "UL";
          }
        }
      }
      list array-carriers {
        key "array-carrier direction";
        leaf array-carrier {
          type string;
        }
        leaf direction {
          type enumeration {
            enum "UL";
          }
        }
      }
      leaf state {
        type enumeration {
          enum "RUNNING";
          enum "COMPLETED";
          enum "FAILED";
          enum "ABORTED";
        }
        config false;
        mandatory true;
      }
      leaf-list files {
        type string;
        config false;
      }
    }
  }

  container rf-scan-captures {
    uses capabilities;
    uses captures;
  }

  notification rf-scan-capture-state-change {
    leaf name {
      type leafref {
        path "/rf-scan-captures/captures/name";
      }
      mandatory true;
    }
    leaf state {
      type leafref {
        path "/rf-scan-captures/captures[name = current()/../name]/state";
      }
      mandatory true;
    }
    leaf-list files {
      type leafref {
        path "/rf-scan-captures/captures[name = current()/../name]/files";
      }
    }
  }
}
</data>
</rpc-reply>
