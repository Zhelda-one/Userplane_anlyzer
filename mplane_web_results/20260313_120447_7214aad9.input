	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-diagnostic-tests-conf {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:diagnostic-tests-conf:1.0";
  prefix ran-ru-diagnostic-tests-conf;

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension for configuration of diagnostic tests executed by NETCONF Server.

     Copyright 2025 Nokia";

  revision 2025-09-23 {
    description
      "Module v0.1:
       1) [CB013490-H/CB013547-H] Corrected typo in diagnostic-test enum value TEMPRATURE-SENSOR to TEMPERATURE-SENSOR.";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v9.0T0.1";
  }
  revision 2024-12-13 {
    description
      "Module v0.1:
       1) [CB013490-H/CB013547-H] Initial module definition";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v9.0T0.1";
  }

  typedef diagnostic-test {
    type enumeration {
      enum "SW-PACKAGE-AND-INTEGRITY";
      enum "MEMORY-USAGE";
      enum "TEMPERATURE-SENSOR";
      enum "EXTENDED-DDR";
    }
  }

  container diagnostic-tests {
    list diagnostic-test-objects {
      key "test";
      leaf test {
        type diagnostic-test;
      }
      leaf state {
        type enumeration {
          enum "SCHEDULED";
          enum "RUNNING";
          enum "COMPLETED";
          enum "FAILED";
        }
        config false;
      }
      leaf result {
        type enumeration {
          enum "OK";
          enum "NOK";
          enum "UNAVAILABLE";
        }
        config false;
      }
    }
    list supported-diagnostic-tests {
      key "test";
      config false;
      leaf test {
        type diagnostic-test;
      }
    }
    list offline-diagnostic-test-results {
      key "test";
      config false;
      leaf test {
        type diagnostic-test;
      }
      leaf result {
        type enumeration {
          enum "OK";
          enum "NOK";
        }
      }
    }
  }

  notification online-diagnostic-test-state-change {
    leaf test {
      type leafref {
        path "/diagnostic-tests/diagnostic-test-objects/test";
      }
    }
    leaf state {
      type leafref {
        path "/diagnostic-tests/diagnostic-test-objects[test = current()/../test]/state";
      }
    }
    leaf result {
      type leafref {
        path "/diagnostic-tests/diagnostic-test-objects[test = current()/../test]/result";
      }
    }
  }
  notification offline-diagnostic-test-finished {
    leaf test {
      type leafref {
        path "/diagnostic-tests/offline-diagnostic-test-results/test";
      }
    }
    leaf result {
      type leafref {
        path "/diagnostic-tests/offline-diagnostic-test-results[test = current()/../test]/result";
      }
    }
  }
}
</data>
</rpc-reply>
