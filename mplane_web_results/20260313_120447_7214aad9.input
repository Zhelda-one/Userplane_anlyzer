  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension module for troubleshooting triggered captures.

     Copyright 2024 Nokia";

  revision 2024-10-09 {
    description
      "Module v0.1:
       1) [CB013298-C]: Added support for troubleshooting data captures configuration and capabilities.";
  }

  typedef troubleshooting-data-scope {
    type enumeration {
      enum "IQ_DATA";
      enum "L1LOW_DATA";
      enum "REGISTER_DUMP";
    }
  }

  grouping capabilities {
    container capabilities {
      config false;
      leaf-list scopes {
        type troubleshooting-data-scope;
        min-elements 1;
      }
    }
  }

  grouping captures {
    list captures {
      key "name";
      leaf name {
        type string;
      }
      leaf scope {
        type troubleshooting-data-scope;
        mandatory true;
      }
      list carriers {
        key "id";
        leaf id {
          type uint32;
        }
        leaf type {
          type enumeration {
            enum "LTE";
            enum "NR";
          }
          mandatory true;
        }
        leaf direction {
          type enumeration {
            enum "DL";
            enum "UL";
          }
          mandatory true;
        }
        leaf frequency {
          type uint64;
          mandatory true;
        }
        leaf bandwidth {
          type uint32;
          mandatory true;
        }
      }
      leaf state {
        type enumeration {
          enum "RUNNING";
          enum "COMPLETED";
          enum "FAILED";
          enum "ABORTED";
        }
        config false;
        mandatory true;
      }
      leaf-list files {
        type string;
        config false;
      }
    }
  }

  container troubleshooting-data-captures {
    uses capabilities;
    uses captures;
  }

  notification troubleshooting-data-capture-state-change {
    leaf name {
      type leafref {
        path "/troubleshooting-data-captures/captures/name";
      }
      mandatory true;
    }
    leaf state {
      type leafref {
        path "/troubleshooting-data-captures/captures[name = current()/../name]/state";
      }
      mandatory true;
    }
    leaf-list files {
      type leafref {
        path "/troubleshooting-data-captures/captures[name = current()/../name]/files";
      }
    }
  }
}
</data>
</rpc-reply>
