    leaf present {
      type boolean;
    }
    leaf rx-power {
      type decimal64 {
        fraction-digits 4;
      }
    }
    leaf tx-power {
      type decimal64 {
        fraction-digits 4;
      }
    }
    leaf tx-bias-current {
      type decimal64 {
        fraction-digits 4;
      }
    }
    leaf voltage {
      type decimal64 {
        fraction-digits 4;
      }
    }
    leaf temperature {
      type decimal64 {
        fraction-digits 4;
      }
    }
    leaf laser-temperature {
      type decimal64 {
        fraction-digits 4;
      }
    }
    leaf tec-current {
      type decimal64 {
        fraction-digits 4;
      }
    }
    leaf high-power-level-state {
