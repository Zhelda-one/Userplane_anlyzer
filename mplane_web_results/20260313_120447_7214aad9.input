<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="10">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-oam-conf {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:oam-conf:1.0";
  prefix ran-ru-oam-conf;

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extensions for the O-RAN Radio Unit Operations and Management
     configuration.

     Copyright 2024 Nokia";

  revision 2024-12-05 {
    description
      "Module v0.1:
       1) [CB010810] Initial module definition containing configuration of SSH server and service account
       2) [CB010810] Bugfix - removal of unnecessary trailing and leading characters in pattern in leaf login-banner";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v0.3";
  }

  feature SSH-SERVER-CONFIG;

  feature SERVICE-ACCOUNT-CONFIG;

  grouping ssh-server-config {
    description
      "Grouping for configuration of SSH server";
    container ssh-server-conf {
      leaf client-alive {
        type uint32 {
          range "0 .. 60";
        }
      }
      leaf login-delay {
        type uint32 {
          range "1 .. 60";
        }
      }
      leaf idle-timeout {
        type uint32 {
          range "0 .. 86400";
        }
      }
      leaf login-banner {
        type string {
          pattern "([^&amp;&lt;]*(&amp;amp;|&amp;lt;))*[^&amp;&lt;]*";
        }
      }
    }
  }

  grouping service-account-config {
    description
      "Grouping for configuration of service account";
    container service-account-conf {
      leaf password {
        type string;
      }
    }
  }

  container oam-configuration {
    description
      "top level container for OAM configuration";
    uses ssh-server-config {
      if-feature "SSH-SERVER-CONFIG";
    }
    uses service-account-config {
      if-feature "SERVICE-ACCOUNT-CONFIG";
    }
  }
}
</data>
</rpc-reply>
