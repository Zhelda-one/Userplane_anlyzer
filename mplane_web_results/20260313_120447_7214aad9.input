	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-operations {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:operations:1.0";
  prefix ran-ru-operations;

  import o-ran-operations {
    prefix o-ran-ops;
  }

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension to O-RAN operations.

     Copyright 2025 Nokia";

  revision 2025-07-07 {
    description
      "Module v0.3:
       1) [CB013668] Added RPC close-mplane-connection with optional feature flag";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v17.0T0.4";
  }
  revision 2024-12-05 {
    description
      "Module v0.2:
       1) [CB013490-J/CB013547-J] Added leaf fail-safe-mode-active";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v9.0T0.1";
  }
  revision 2024-11-06 {
    description
      "Module v0.1:
       1) [CB013026] Specified maximum value length for leaves info and gpp within container reset-info";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v6.0T0.2";
  }
  revision 2024-09-24 {
    description
      "Module v0.1:
       1) [CB013026] Initial draft containing definitions for diagnostics parity to RP1/SOAP";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v3.0T0.3";
  }

  feature CLOSE-MPLANE-CONNECTION;

  feature RESET-INFO;

  augment "/o-ran-ops:operational-info/o-ran-ops:operational-state" {
    container reset-info {
      if-feature "RESET-INFO";
      leaf reset-counter {
        type uint32;
      }
      leaf info {
        type string {
          length "1..900";
        }
      }
      leaf gpp {
        type string {
          length "1..900";
        }
      }
    }
    leaf fail-safe-mode-active {
      type boolean;
    }
  }

  rpc close-mplane-connection {
    if-feature "CLOSE-MPLANE-CONNECTION";

    input {
      leaf reconnection-delay {
        type uint32 {
          range "0 .. 900";
        }
        default "0";
      }
      leaf max-call-home-attempts {
        type uint32 {
          range "0 .. 20";
        }
        default "20";
      }
      leaf re-call-home-timer {
        type uint16 {
          range "1 .. 900";
        }
        default "5";
      }
    }
  }
}
</data>
