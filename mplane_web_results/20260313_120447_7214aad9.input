<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="22">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-vswr-conf {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:vswr-conf:1.0";
  prefix ran-ru-vswr-conf;

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extensions for the Voltage Standing Wave Ratio configuration.

     Copyright 2024 Nokia";

  revision 2024-06-20 {
    description
      "Module v0.1:
       1) [CB010810] Initial module definition containing configuration of power and VSWR thresholds for VSWR alarms";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v0.4";
  }

  feature VSWR-ALARM-THRESHOLDS;

  grouping vswr-alarm-config {
    description
      "Grouping for configuration of VSWR alarms";
    list vswr-alarm-conf {
      key "tx-array-name array-element-id";
      config true;
      leaf tx-array-name {
        type string;
      }
      leaf array-element-id {
        type uint16;
      }
      leaf vswr-minor-threshold {
        type decimal64 {
          fraction-digits 4;
        }
      }
      leaf vswr-major-threshold {
        type decimal64 {
          fraction-digits 4;
        }
      }
      leaf vswr-power-threshold {
        type decimal64 {
          fraction-digits 4;
        }
      }
    }
  }

  container vswr-configuration {
    description
      "top level container for VSWR configuration";
    uses vswr-alarm-config {
      if-feature "VSWR-ALARM-THRESHOLDS";
    }
  }
}
</data>
</rpc-reply>
