  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:pim-cancellation-conf:1.0";
  prefix ran-ru-pim-cancellation-conf;

  import o-ran-uplane-conf {
    prefix up;
  }

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extensions for PIM (passive intermodulation) cancellation configuration.

     Copyright 2024 Nokia";

  revision 2024-11-06 {
    description
      "Module v0.1:
       1) [CB012186] Initial module definition containing configuration of PIM cancellation and thresholds for the related alarms";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v6.0T0.2";
  }

  grouping pim-cancellation-config {
    description
      "Grouping for configuration of PIM cancellation";
    list pim-cancellation-conf {
      key "rx-array-name array-element-id";
      config true;
      leaf rx-array-name {
        type leafref {
          path "/up:user-plane-configuration/up:rx-arrays/up:name";
          require-instance false;
        }
      }
      leaf array-element-id {
