<rpc message-id="21" xmlns="urn:ietf:params:xml:ns:netconf:base:1.0">
	<get-schema xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">
		<identifier>nokia-ran-ru-uplane-conf</identifier>
		<version>2026-01-27</version>
		<format xmlns:ncm="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">ncm:yang</format>
	</get-schema>
</rpc>
[2026-02-23 16:54:40.248200];RECV;15168bytes
<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="21">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-uplane-conf {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:uplane-conf:1.0";
  prefix ran-ru-uplane-conf;

  import o-ran-uplane-conf {
    prefix up;
  }
  import ietf-interfaces {
    prefix if;
  }
  import iana-if-type {
    prefix ianaift;
  }
  import o-ran-processing-element {
    prefix o-ran-pe;
  }
  import o-ran-compression-factors {
    prefix o-ran-cf;
  }

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension module capabilities for
     the O-RAN Radio Unit U-Plane configuration.

     Copyright 2026 Nokia";

  revision 2026-01-27 {
    description
      "Module v0.5:
       1) [CB015283/CB015284] Introduced power pooling for downlink array carriers";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v31.0T2.3";
  }
  revision 2025-12-18 {
    description
      "Module v0.4:
       1) [CB015747-H] Added optional feature flags: RUNTIME-SRS-SINR-THRESHOLD-MODIFICATION, RUNTIME-SRS-POWER-THRESHOLD-MODIFICATION";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v31.0T0.1";
  }
  revision 2025-11-03 {
    description
      "Module v0.3:
       1) [CB014308-B] Added additional nodes for 7-2e configuration to combining-links list and the relevant optional feature flags";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v23.0T2.2";
  }
  revision 2025-04-03 {
    description
      "Module v0.1:
       1) Modified list supported-interfaces to be a container instead";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v15.0T2.1";
  }
  revision 2025-03-11 {
    description
      "Module v0.2:
       1) Corrected definitions for 7-2e FH split support";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v12.0T0.3";
  }
  revision 2024-10-25 {
    description
      "Module v0.2:
       1) Initial draft containing definitions for 7-2e FH split support";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v5.0T1.2";
  }

  feature SUPPORTED-INTERFACES;

  feature UPLINK-COMBINING;

  feature DOWNLINK-MODULATION;

  feature PERIODIC-SRS;

  feature DOWNLINK-SUBBAND-BEAMFORMING;

  feature SRS-TOE-WITH-PRECOMBINE;

  feature HIGH-SPEED-CELL;

  feature PMI-SINR-UL-MU-MIMO-ENHANCEMENT;

  feature RIM-RS-DETECTION-THRESHOLD;

  feature RUNTIME-SRS-SINR-THRESHOLD-MODIFICATION;

  feature RUNTIME-SRS-POWER-THRESHOLD-MODIFICATION;

  feature PA-POWER-POOLING;

  typedef sc-type {
    type enumeration {
      enum "C4_2";
      enum "C16_2";
      enum "C16_4";
      enum "C16_8";
    }
  }

  grouping real-imaginary-parts {
    leaf real-part {
      type uint16;
      mandatory true;
    }
    leaf imaginary-part {
      type uint16;
      mandatory true;
    }
  }

  grouping eaxc {
    leaf o-du-port-bitmask {
      type uint16;
      mandatory true;
    }
    leaf band-sector-bitmask {
      type uint16;
      mandatory true;
    }
    leaf ccid-bitmask {
      type uint16;
      mandatory true;
    }
    leaf ru-port-bitmask {
      type uint16;
      mandatory true;
    }
    leaf eaxc-id {
      type uint16;
      mandatory true;
    }
  }

  grouping uplink-combining-config {
    description
      "Grouping for combining-endpoints and combining-links configuration";
    list combining-endpoint-types {
      key "name";
      config false;
      leaf name {
        type string;
      }
      leaf-list supported-subcell-types {
        type sc-type;
        min-elements 1;
      }
    }
    list static-combining-endpoints {
      key "name";
      config false;
      leaf name {
        type string;
      }
      leaf combining-endpoint-type {
        type leafref {
          path "/user-plane-configuration/combining-endpoint-types/name";
        }
        mandatory true;
      }
      leaf-list restricted-interfaces {
        type leafref {
          path "/if:interfaces/if:interface/if:name";
        }
        must "/if:interfaces/if:interface[if:name=current()]/if:type = 'ianaift:ethernetCsmacd'";
      }
      leaf rx-array {
        type leafref {
          path "/up:user-plane-configuration/up:rx-arrays/up:name";
        }
        must "count(/up:user-plane-configuration/up:rx-arrays[up:name=current()]/up:polarisations) = 2";
        mandatory true;
      }
    }
    list combining-endpoints {
      key "name";
      config true;
      leaf name {
        type leafref {
          path "/user-plane-configuration/static-combining-endpoints/name";
          require-instance false;
        }
      }
      container e-axcid {
        uses eaxc;
      }
      container format {
        leaf iq-bitwidth {
          type uint8;
          mandatory true;
        }
        leaf fs-offset {
          type uint8;
          default "0";
        }
        leaf compression-type {
          type o-ran-cf:compression-type-def;
          mandatory true;
        }
        leaf compression-method {
          type o-ran-cf:compression-method-def;
          mandatory true;
        }
      }
      leaf scaling-exponent {
        type uint16;
        default "0";
      }
      leaf ul-fft-sampling-offset {
        type uint16;
        default "0";
      }
    }
    list combining-links {
      key "name";
      config true;
      leaf name {
        type string;
      }
      leaf rx-array-carrier {
        type leafref {
          path "/up:user-plane-configuration/up:rx-array-carriers/up:name";
        }
        mandatory true;
      }
      list data-endpoints {
        key "combining-endpoint";
        min-elements 1;
        leaf combining-endpoint {
          type leafref {
            path "/user-plane-configuration/combining-endpoints/name";
          }
        }
        leaf processing-element {
          type leafref {
            path "/o-ran-pe:processing-elements/o-ran-pe:ru-elements/o-ran-pe:name";
          }
          mandatory true;
        }
      }
      list normalization-endpoints {
        key "combining-endpoint";
        min-elements 1;
        leaf combining-endpoint {
          type leafref {
            path "/user-plane-configuration/combining-endpoints/name";
          }
        }
        leaf processing-element {
          type leafref {
            path "/o-ran-pe:processing-elements/o-ran-pe:ru-elements/o-ran-pe:name";
          }
          mandatory true;
        }
      }
      leaf phys-cell-id {
        type uint16;
        mandatory true;
      }
      container srs-config {
        leaf transmission-comb {
          type uint16 {
            range "2 | 4";
          }
        }
        leaf sequence-id {
          type uint16 {
            range "0..1007";
          }
        }
      }
      container periodic-srs-config {
        if-feature "PERIODIC-SRS";
        leaf periodic-srs-active {
          type boolean;
          default "false";
        }
        leaf num-prb-per-subband {
          type uint16 {
            range "4..272";
          }
          must "current()/../periodic-srs-active";
        }
      }
      leaf subcell-type {
        type sc-type;
        mandatory true;
      }
      container dl-subband-beamforming {
        if-feature "DOWNLINK-SUBBAND-BEAMFORMING";
        leaf dl-subband-bf-act {
          type boolean;
          default "false";
        }
        leaf bf-subband-size {
          type uint16 {
            range "2 | 4";
          }
          must "current()/../dl-subband-bf-act";
        }
        leaf srs-subband-size {
          type uint16 {
            range "0 .. 272";
          }
          must "current()/../dl-subband-bf-act";
        }
        leaf srs-power-threshold {
          type int16 {
            range "-1500 .. 0";
          }
          must "current()/../dl-subband-bf-act";
        }
        leaf srs-sinr-threshold {
          type int16 {
            range "-400 .. 400";
          }
          must "current()/../dl-subband-bf-act";
        }
        leaf num-of-ul-blanked-prbs-high-edge {
          type uint16 {
            range "0 .. 82";
          }
          must "current()/../dl-subband-bf-act";
        }
        leaf num-of-ul-blanked-prbs-low-edge {
          type uint16 {
            range "0 .. 82";
          }
          must "current()/../dl-subband-bf-act";
        }
        container precombination-beam {
          when "../dl-subband-bf-act";
          if-feature "SRS-TOE-WITH-PRECOMBINE";
          list horizontal-weight-vectors {
            key "array-column-id";
            leaf array-column-id {
              type uint16;
            }
            uses real-imaginary-parts;
          }
          list vertical-weight-vectors {
            key "array-row-id";
            leaf array-row-id {
              type uint16;
            }
            uses real-imaginary-parts;
          }
        }
        leaf transmission-comb-subband-bf {
          type uint16 {
            range "2 | 4";
          }
          must "current()/../dl-subband-bf-act";
        }
      }
      leaf high-speed-cell {
        if-feature "HIGH-SPEED-CELL";
        type boolean;
        default "false";
      }
      leaf rdd-averaging-prb-size {
        type uint16 {
          range "0 .. 5";
        }
        default "2";
      }
      leaf rdd-debiasing {
        type boolean;
        default "true";
      }
      leaf pmi-sinr-ul-mu-mimo-enhancement {
        if-feature "PMI-SINR-UL-MU-MIMO-ENHANCEMENT";
        type boolean;
        default "false";
      }
      leaf rim-rs-detection-threshold {
        if-feature "RIM-RS-DETECTION-THRESHOLD";
        type uint16 {
          range "20 .. 1000";
        }
        default "20";
      }
    }
  }

  grouping downlink-modulation-config {
    description
      "Grouping for modulation-endpoints and modulation-links configuration";
    list static-modulation-endpoints {
      key "name";
      config false;
      leaf name {
        type string;
      }
      leaf-list restricted-interfaces {
        type leafref {
          path "/if:interfaces/if:interface/if:name";
        }
        must "/if:interfaces/if:interface[if:name=current()]/if:type = 'ianaift:ethernetCsmacd'";
      }
      leaf tx-array {
        type leafref {
          path "/up:user-plane-configuration/up:tx-arrays/up:name";
        }
        must "count(/up:user-plane-configuration/up:tx-arrays[up:name=current()]/up:polarisations) = 2";
        mandatory true;
      }
    }
    list modulation-endpoints {
      key "name";
      config true;
      leaf name {
        type leafref {
          path "/user-plane-configuration/static-modulation-endpoints/name";
          require-instance false;
        }
      }
      container e-axcid {
        uses eaxc;
      }
    }
    list modulation-links {
      key "name";
      config true;
      leaf name {
        type string;
      }
      leaf tx-array-carrier {
        type leafref {
          path "/up:user-plane-configuration/up:tx-array-carriers/up:name";
        }
        mandatory true;
      }
      list modulation-endpoints {
        key "modulation-endpoint";
        min-elements 1;
        leaf modulation-endpoint {
          type leafref {
            path "/user-plane-configuration/modulation-endpoints/name";
          }
        }
        leaf processing-element {
          type leafref {
            path "/o-ran-pe:processing-elements/o-ran-pe:ru-elements/o-ran-pe:name";
          }
          mandatory true;
        }
      }
      leaf phys-cell-id {
        type uint16;
        mandatory true;
      }
      leaf mimo-mode {
        type enumeration {
          enum "CL_2x2_MIMO";
          enum "CL_4x4_OR_4x2_MIMO";
          enum "CL_8x4_MIMO";
          enum "OL_2x2_MIMO";
          enum "OL_4x4_OR_4x2_MIMO";
        }
        mandatory true;
      }
      container ss-block {
        leaf ss-block-power {
          type int16;
          mandatory true;
        }
        leaf ss-block-prb-offset {
          type uint16;
          mandatory true;
        }
        leaf ss-block-subcarrier-offset {
          type uint16;
          mandatory true;
        }
        leaf ss-block-configuration {
          type enumeration {
            enum "CASE_A";
            enum "CASE_B";
            enum "CASE_C";
          }
          mandatory true;
        }
      }
      leaf conformance-test-mode {
        type boolean;
        default "false";
      }
      container dl-subband-beamforming {
        if-feature "DOWNLINK-SUBBAND-BEAMFORMING";
        leaf dl-subband-bf-act {
          type boolean;
          default "false";
        }
        leaf bf-subband-size {
          type uint16 {
            range "2 | 4";
          }
          must "current()/../dl-subband-bf-act";
        }
        leaf bf-method {
          type enumeration {
            enum "BF_METHOD_MMSE";
            enum "BF_METHOD_SVD";
          }
          must "current()/../dl-subband-bf-act";
        }
      }
    }
  }

  grouping supported-interfaces-config {
    description
      "Grouping for supported-interfaces configuration";
    container supported-interfaces {
      config false;
      list supported-7-2e-fh-messages {
        must "count(current()) &gt; 0 or not(/user-plane-configuration/combining-endpoints)";
        key "id";
        config false;
        leaf id {
          type uint32;
        }
      }
    }
  }

  grouping power-pooling-config {
    description
      "Grouping for power pooling configuration";
    container power-pooling-capabilities {
      config false;
      leaf-list carrier-types {
        type leafref {
          path "/up:user-plane-configuration/up:tx-array-carriers/up:type";
          require-instance false;
        }
        min-elements 1;
      }
      list pa-path-sets {
        key "pa-id";
        min-elements 1;
        leaf pa-id {
          type uint8 {
            range "1..max";
          }
        }
        leaf-list paths {
          type leafref {
            path "/up:user-plane-configuration/up:tx-arrays/up:name";
          }
          min-elements 1;
        }
      }
    }
    list pa-power-pools {
      key "name";
      leaf name {
        type string;
      }
      leaf max-power {
        type decimal64 {
          fraction-digits 1;
        }
        mandatory true;
      }
      leaf pa-id {
        type uint8 {
          range "1..max";
        }
        mandatory true;
      }
    }
  }

  container user-plane-configuration {
    description
      "top level container for user plane configuration";
    uses uplink-combining-config {
      if-feature "UPLINK-COMBINING";
    }
    uses downlink-modulation-config {
      if-feature "DOWNLINK-MODULATION";
    }
    uses supported-interfaces-config {
      if-feature "SUPPORTED-INTERFACES";
    }
    uses power-pooling-config {
      if-feature "PA-POWER-POOLING";
    }
  }
}
</data>
</rpc-reply>
