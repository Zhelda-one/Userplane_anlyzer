<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="26">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module unix-domain-socket-call-home {
  yang-version 1.1;
  namespace "urn:ietf:params:xml:ns:yang:unix-domain-socket-call-home";
  prefix udsch;

  import ietf-netconf-server {
    prefix ins;
    revision-date 2019-07-02;
  }

  revision 2024-07-02 {
    description
      "Initial version";
  }

  augment "/ins:netconf-server/ins:call-home/ins:netconf-client/ins:endpoints/ins:endpoint/ins:transport" {
    case uds {
      container uds {
        description
          "Specifies UDS-specific call-home transport
           configuration.";
        container uds-parameters {
          leaf name {
            type string;
            description
              "Unix domain socket name.";
          }
          leaf abstract {
            type empty;
            description
              "If present, abstract sockets should be used.";
          }
        }
      }
    }
  }
}
</data>
