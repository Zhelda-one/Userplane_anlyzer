        mandatory true;
      }
      list carriers {
        key "id";
        leaf id {
          type uint32;
        }
        leaf type {
          type enumeration {
            enum "LTE";
            enum "NR";
          }
          mandatory true;
        }
        leaf direction {
          type enumeration {
            enum "DL";
            enum "UL";
          }
          mandatory true;
        }
        leaf frequency {
          type uint64;
          mandatory true;
        }
        leaf bandwidth {
          type uint32;
          mandatory true;
        }
      }
      leaf state {
        type enumeration {
          enum "RUNNING";
          enum "COMPLETED";
          enum "FAILED";
          enum "ABORTED";
        }
        config false;
        mandatory true;
      }
      leaf-list files {
        type string;
        config false;
      }
    }
  }

  container troubleshooting-data-captures {
    uses capabilities;
    uses captures;
  }

  notification troubleshooting-data-capture-state-change {
    leaf name {
      type leafref {
        path "/troubleshooting-data-captures/captures/name";
      }
      mandatory true;
    }
    leaf state {
      type leafref {
        path "/troubleshooting-data-captures/captures[name = current()/../name]/state";
      }
      mandatory true;
    }
    leaf-list files {
      type leafref {
        path "/troubleshooting-data-captures/captures[name = current()/../name]/files";
      }
    }
  }
}
</data>
</rpc-reply>
