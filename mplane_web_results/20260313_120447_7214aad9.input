  import o-ran-transceiver {
    prefix o-ran-trx;
  }

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension module capabilities for transceivers configuration.

     Copyright 2026 Nokia";

  revision 2026-01-27 {
    description
      "Module v0.4:
       1) [PR868723] Added typedefs for high-power-level-state and temperature-too-low leafs, modified non-key leafs in
       notification port-transceiver-data-change to use actual leaf types instead of leafrefs";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v35.0T0.1";
  }
  revision 2025-03-12 {
    description
      "Module v0.4:
       1) [CB013427] Renamed container for DWDM tunable transceiver info from tunable-transceiver-capabilities to
       tunable-transceiver-info, renamed leaf tuning-in-progress to self-tuning-in-progress
       2) [CB013427-E] Extended the notification port-transceiver-data-change with DWDM tunable transceiver leafs";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v12.0T1.2";
  }
  revision 2025-01-13 {
    description
      "Module v0.3:
       1) [CB013490-D] Added the following leaves in o-ran-trx:port-transceiver-data:
         temperature-too-high, tx-bias-current-too-low, tx-power-too-low, rx-power-too-low, rx-los, tx-fault
       2) [CB013490-D] Added notification port-transceiver-data-change";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v8.0T1.3";
  }
  revision 2024-12-06 {
    description
      "Module v0.2:
       1) [CB013427] Adding DWDM tunable transceiver capabilities";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v6.0T1.2";
  }
  revision 2024-08-01 {
    description
      "Module v0.1:
       1) Initial draft containing definitions for transceivers configuration parity to RP1/SOAP";
    reference
      "eCPRI LL Split Nokia Proprietary NETCONF/Yang M-Plane Specification v1.1";
  }

  typedef transceiver-high-power-level-state {
    type enumeration {
      enum "NOT-REQUIRED";
      enum "INACTIVE";
      enum "ACTIVE";
      enum "INACTIVE-FAILED";
    }
  }

  typedef transceiver-temperature-low-state {
    type enumeration {
      enum "NOT-DETERMINED";
      enum "NO-WARNING";
      enum "WARNING";
      enum "ALARM";
    }
  }

  augment "/o-ran-trx:port-transceivers/o-ran-trx:port-transceiver-data" {
    leaf laser-temperature {
      type decimal64 {
        fraction-digits 4;
      }
      config false;
    }
    leaf tec-current {
      type decimal64 {
        fraction-digits 4;
      }
      config false;
    }
    leaf power-level-compatibility-state {
      type enumeration {
        enum "COMPATIBLE";
        enum "INCOMPATIBLE";
      }
      config false;
    }
    leaf high-power-level-state {
      type transceiver-high-power-level-state;
      config false;
    }
    leaf temperature-low-state {
      type transceiver-temperature-low-state;
      config false;
    }
    leaf compliance-validation-result {
      type enumeration {
        enum "COMPLIANT";
        enum "INCOMPLIANT";
      }
      config false;
    }
    leaf temperature-too-high {
      type uint8 {
        range "0..3";
      }
      config false;
    }
    leaf tx-bias-current-too-low {
      type uint8 {
        range "0..3";
      }
      config false;
    }
    leaf tx-power-too-low {
      type uint8 {
        range "0..3";
      }
      config false;
    }
    leaf rx-power-too-low {
      type uint8 {
        range "0..3";
      }
      config false;
    }
    leaf rx-los {
      type uint8 {
        range "0..2";
      }
      config false;
    }
    leaf tx-fault {
      type uint8 {
        range "0..2";
      }
      config false;
    }
    container tunable-transceiver-info {
      config false;
      leaf tuning-supported {
        type boolean;
      }
      leaf self-tuning-supported {
        type boolean;
      }
      leaf dwdm-first-channel-frequency {
        type uint32 {
          range "191300..196100";
        }
      }
      leaf dwdm-last-channel-frequency {
        type uint32 {
          range "191300..196100";
        }
      }
      leaf dwdm-channel-grid-spacing {
        type uint32 {
          range "125..1000";
        }
      }
      leaf dwdm-channel-wavelength-tuning-supported {
        type boolean;
      }
      leaf dwdm-channel-number-tuning-supported {
        type boolean;
      }
      leaf self-tuning-in-progress {
        type boolean;
      }
      leaf tuned-dwdm-channel-wavelength {
        type decimal64 {
          range "1528.7700..1567.1300";
          fraction-digits 4;
        }
      }
      leaf tuned-dwdm-channel-frequency-error {
        type decimal64 {
          fraction-digits 4;
        }
      }
      leaf tuned-dwdm-channel-wavelength-error {
        type decimal64 {
          fraction-digits 4;
        }
      }
      leaf tec-fault {
        type boolean;
      }
    }
  }

  notification port-transceiver-data-change {
    leaf interface-name {
      type leafref {
        path "/o-ran-trx:port-transceivers/o-ran-trx:port-transceiver-data/o-ran-trx:interface-name";
      }
      mandatory true;
    }
    leaf port-number {
