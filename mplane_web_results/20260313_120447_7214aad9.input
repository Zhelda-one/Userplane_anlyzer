      }
      leaf pim-cancellation-enabled {
        type boolean;
        default "false";
      }
      leaf pim-level-major-threshold {
        type int32;
        default "-130";
      }
      leaf pim-level-minor-threshold {
        type int32;
        default "-140";
      }
    }
  }

  container pim-cancellation-configuration {
    description
      "top level container for PIM cancellation configuration";
    uses pim-cancellation-config;
  }
}
