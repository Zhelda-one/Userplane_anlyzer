<rpc-reply xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="18">
	<data xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-monitoring">module nokia-ran-ru-troubleshooting {
  yang-version 1.1;
  namespace "urn:nokia.com:ran:ru:troubleshooting:1.0";
  prefix ran-ru-troubleshooting;

  import o-ran-troubleshooting {
    prefix o-ran-trbl;
  }

  organization
    "Nokia";
  contact
    "www.nokia.com";
  description
    "This module defines the Nokia proprietary extension module for troubleshooting.

     Copyright 2025 Nokia";

  revision 2025-12-09 {
    description
      "Module v0.3:
       1) [CB014935]: Added support for selection of troubleshooting log coverage in start-troubleshooting-logs RPC.";
  }
  revision 2025-10-16 {
    description
      "Module v0.2:
       1) [CB014308-C]: Added nodes for troubleshooting log capabilities reporting and troubleshooting log control.";
  }
  revision 2024-10-09 {
    description
      "Module v0.1:
       1) [CB013298-C]: Added support for filtering the troubleshooting logs with file name patterns.";
  }

  feature TROUBLESHOOTING-LOG-CONTROL;

  feature TROUBLESHOOTING-LOG-COVERAGE;

  grouping troubleshooting-log-capabilities {
    list supported-logging-domains {
      key "domain subdomain";
      config false;
      leaf domain {
        type string;
      }
      leaf subdomain {
        type string;
      }
      leaf max-verbosity {
        type uint32;
      }
      leaf default-verbosity {
        type uint32;
      }
    }
  }

  grouping troubleshooting-log-control {
    list verbosity-configuration {
      key "domain subdomain";
      leaf domain {
        type leafref {
          path "/troubleshooting-configuration/supported-logging-domains/domain";
          require-instance false;
        }
      }
      leaf subdomain {
        type leafref {
          path "/troubleshooting-configuration/supported-logging-domains[domain = current()/../domain]/subdomain";
          require-instance false;
        }
      }
      leaf verbosity {
        type uint32;
      }
      leaf persistence {
        type enumeration {
          enum "NON-PERSISTENT";
          enum "ONE-RESET";
        }
      }
    }
  }

  container troubleshooting-configuration {
    uses troubleshooting-log-capabilities {
      if-feature "TROUBLESHOOTING-LOG-CONTROL";
    }
    uses troubleshooting-log-control {
      if-feature "TROUBLESHOOTING-LOG-CONTROL";
    }
  }

  augment "/o-ran-trbl:start-troubleshooting-logs/o-ran-trbl:input" {
    leaf-list file-name-patterns {
      type string;
    }
    leaf coverage {
      if-feature "TROUBLESHOOTING-LOG-COVERAGE";
      type enumeration {
        enum "FULL";
        enum "MINOR";
        enum "BLACKBOX";
      }
    }
  }
}
</data>
</rpc-reply>
